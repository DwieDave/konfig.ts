{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"emitDeclarationOnly": true,
		"declaration": true,
		"declarationMap": true,
		"composite": false,
		"incremental": false,
		"declarationDir": "./dist",
		"rootDir": "./src"
	},
	"include": ["./src/**/*.ts", "./src/.generated/**/*.ts"],
	"exclude": ["./node_modules/**/*", "./dist/**/*", "./src/**/*.test.ts"]
}

{
	"name": "@konfig.ts/k8s",
	"version": "0.0.1",
	"description": "Kubernetes resource builders (workloads, network, identity, policy, volume, env) for konfig.ts.",
	"license": "MIT",
	"author": "David Stahl-Gruber",
	"homepage": "https://github.com/PLACEHOLDER/konfig.ts#readme",
	"bugs": "https://github.com/PLACEHOLDER/konfig.ts/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PLACEHOLDER/konfig.ts.git",
		"directory": "packages/k8s"
	},
	"keywords": ["kubernetes", "k8s", "config", "effect", "typescript"],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": ["dist", "README.md", "LICENSE"],
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.mts",
				"import": "./dist/index.mjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown ./src/index.ts --format=esm --target=node20 --dts --sourcemap --clean",
		"check": "tsc -p tsconfig.check.json --noEmit",
		"test": "bunx vitest run $(rg --files src -g '*.test.ts')",
		"lint": "oxlint",
		"lint:apply": "oxlint --fix",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@konfig.ts/core": "workspace:*",
		"kubernetes-types": "^1.30.0"
	},
	"peerDependencies": {
		"effect": "4.0.0-beta.52"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:",
		"@types/bun": "catalog:",
		"effect": "catalog:",
		"fast-check": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}

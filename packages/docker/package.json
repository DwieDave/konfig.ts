{
  "name": "@konfig.ts/docker",
  "version": "0.0.10",
  "description": "Workspace-graph-aware Dockerfile generator for konfig.ts monorepos.",
  "license": "MIT",
  "author": "David Stahl-Gruber",
  "homepage": "https://github.com/DwieDave/konfig.ts#readme",
  "bugs": "https://github.com/DwieDave/konfig.ts/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DwieDave/konfig.ts.git",
    "directory": "packages/docker"
  },
  "keywords": ["docker", "dockerfile", "monorepo", "workspace", "konfig", "effect", "typescript"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown ./src/index.ts --format=esm --target=node22 --sourcemap --clean --no-dts && tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.check.json --noEmit",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:apply": "oxlint --fix",
    "prepublishOnly": "bun run build",
    "prepack": "node ../../scripts/prepack-exports.mjs strip",
    "postpack": "node ../../scripts/prepack-exports.mjs restore"
  },
  "dependencies": {
    "@konfig.ts/core": "workspace:*",
    "yaml": "catalog:"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "effect": "catalog:",
    "fast-check": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

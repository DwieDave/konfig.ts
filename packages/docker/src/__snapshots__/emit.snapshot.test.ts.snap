exports[`emit snapshots — bun fixture > full-featured spec > bun-full-Dockerfile 1`] = `
"# konfig-managed: @konfig.ts/docker
# spec: packages/app/docker.ts
# hash: sha256:a08444016490aba350c23a324a38d2ddfa92c6b172539e287667c2d2292d634f
FROM oven/bun:1.3.5-alpine AS base

FROM base AS deps
WORKDIR /app
COPY package.json bun.lock bunfig.toml ./
COPY packages/app/package.json ./packages/app/
COPY packages/other/package.json ./packages/other/
COPY packages/shared/package.json ./packages/shared/
COPY packages/util/package.json ./packages/util/
RUN bun install --ignore-scripts

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules /app/node_modules
COPY --from=deps /app/packages/shared/node_modules /app/packages/shared/node_modules
COPY --from=deps /app/packages/util/node_modules /app/packages/util/node_modules
COPY --from=deps /app/packages/app/node_modules /app/packages/app/node_modules
COPY packages/shared ./packages/shared
COPY packages/util ./packages/util
COPY packages/app ./packages/app
WORKDIR /app/packages/app
RUN bun run build

FROM --platform=linux/amd64 base AS runner
WORKDIR /app/packages/app
RUN addgroup -S -g 1234 myapp && adduser -S -u 1234 -G myapp myapp
ENV LOG_LEVEL=info NODE_ENV=production
EXPOSE 4000
EXPOSE 9229
COPY --from=builder --chown=myapp:myapp /app/node_modules /app/node_modules
COPY --from=builder --chown=myapp:myapp /app/packages/app/dist /app/packages/app/dist
COPY --from=builder --chown=myapp:myapp /app/packages/shared /app/packages/shared
COPY --from=builder --chown=myapp:myapp /app/packages/util /app/packages/util
COPY --from=builder --chown=myapp:myapp /app/packages/shared/node_modules /app/packages/shared/node_modules
COPY --from=builder --chown=myapp:myapp /app/packages/util/node_modules /app/packages/util/node_modules
COPY --from=builder --chown=myapp:myapp /app/packages/app/node_modules /app/packages/app/node_modules
HEALTHCHECK --interval=30s CMD ["wget","--spider","-q","http://localhost:4000/healthz"]
USER myapp
CMD ["bun","run","dist/main.js"]
"
`;


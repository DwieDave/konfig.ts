"# konfig-managed: @konfig.ts/docker
# spec: packages/app/docker.ts
# hash: sha256:1a3009c5e7c516cd1b7bf8a7257899c9284248a0b13bcc8c03295664d84b1cb1
FROM node:22-alpine AS base

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY packages/app/package.json ./packages/app/
COPY packages/other/package.json ./packages/other/
COPY packages/shared/package.json ./packages/shared/
COPY packages/util/package.json ./packages/util/
RUN corepack enable pnpm && corepack prepare pnpm@9.7.0 --activate
RUN pnpm install --frozen-lockfile --ignore-scripts

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules /app/node_modules
COPY packages/shared ./packages/shared
COPY packages/util ./packages/util
COPY packages/app ./packages/app
WORKDIR /app/packages/app
RUN pnpm run build

FROM base AS runner

{
	"name": "@konfig.ts/core",
	"version": "0.0.1",
	"description": "Core abstractions (Manifest, RenderContext, Helm, deps) for konfig.ts — typesafe Kubernetes + ArgoCD config in TypeScript.",
	"license": "MIT",
	"author": "David Stahl-Gruber",
	"homepage": "https://github.com/DwieDave/konfig.ts#readme",
	"bugs": "https://github.com/DwieDave/konfig.ts/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DwieDave/konfig.ts.git",
		"directory": "packages/core"
	},
	"keywords": ["kubernetes", "k8s", "argocd", "config", "effect", "typescript"],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"files": ["dist", "README.md", "LICENSE"],
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.mjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown ./src/index.ts --format=esm --target=node20 --sourcemap --clean --no-dts && tsc -p tsconfig.build.json",
		"check": "tsc -p tsconfig.check.json --noEmit",
		"test": "bunx vitest run $(rg --files src -g '*.test.ts')",
		"lint": "oxlint",
		"lint:apply": "oxlint --fix",
		"prepublishOnly": "bun run build"
	},
	"peerDependencies": {
		"effect": "4.0.0-beta.52",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:",
		"@types/bun": "catalog:",
		"effect": "catalog:",
		"fast-check": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"yaml": "catalog:"
	}
}
